---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  category: 'system-design' | 'dsa' | 'error-fix' | 'frameworks';
  pubDate: Date;
  updatedDate?: Date;
  readingTime?: string;
}

const { title, description, category, pubDate, updatedDate, readingTime } = Astro.props;

const categoryLabel: Record<string, string> = {
  'system-design': 'System design',
  'dsa': 'DSA',
  'error-fix': 'Error fix',
  'frameworks': 'Frameworks',
};

const categoryColor: Record<string, string> = {
  'system-design': 'var(--purple)',
  'dsa': 'var(--blue)',
  'error-fix': 'var(--orange)',
  'frameworks': 'var(--lime)',
};

const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<Layout title={title} description={description} active="posts">
  <article class="dark post-hero">
    <div class="blob" style={`width:300px;height:300px;top:-80px;right:0;background:${categoryColor[category]};opacity:0.35;`}></div>
    <a href="/blog" class="back-link">← All posts</a>
    <span class={`badge ${category}`}>{categoryLabel[category]}</span>
    <h1 class="reveal in">{title}</h1>
    <div class="post-meta muted">
      <span>{formattedDate}</span>
      {readingTime && <><span>·</span><span>{readingTime}</span></>}
      {updatedDate && <><span>·</span><span>Updated {updatedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span></>}
    </div>
  </article>

  <article class="dark post-body">
    <div class="prose">
      <slot />
    </div>
  </article>
</Layout>

<style>
  .post-hero { position: relative; max-width: 760px; margin: 0 auto; padding: 64px 32px 48px; display: flex; flex-direction: column; gap: 18px; align-items: flex-start; }
  .back-link { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; color: var(--muted); margin-bottom: 4px; transition: color .2s ease; }
  .back-link:hover { color: var(--orange-2); }
  .post-hero h1 { font-size: 38px; font-weight: 800; line-height: 1.15; }
  .post-meta { font-size: 13px; font-family: 'JetBrains Mono', monospace; display: flex; gap: 8px; }

  .post-body { padding: 50px 32px 110px; }
  .prose { max-width: 700px; margin: 0 auto; font-size: 16.5px; line-height: 1.85; color: var(--text); }
  .prose :global(h2) { font-size: 26px; font-weight: 700; margin: 48px 0 16px; }
  .prose :global(h2)::before { content: "// "; color: var(--orange-2); font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.7em; }
  .prose :global(h3) { font-size: 20px; font-weight: 700; margin: 32px 0 12px; color: var(--purple-2); }
  .prose :global(p) { margin-bottom: 20px; color: var(--muted); }
  .prose :global(a) { color: var(--orange-2); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 20px 22px; color: var(--muted); }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(li)::marker { color: var(--orange-2); }
  .prose :global(code) { background: rgba(255,255,255,0.08); color: var(--lime); padding: 2px 7px; border-radius: 5px; font-size: 0.88em; }

  /* code fences rendered as terminal windows */
  .prose :global(pre) {
    background: #0D0D14; color: var(--text); padding: 0; border-radius: 14px; overflow: hidden;
    margin: 0 0 28px; border: 1px solid rgba(255,255,255,0.10);
    box-shadow: 0 25px 60px rgba(0,0,0,0.45);
    position: relative;
  }
  .prose :global(pre)::before {
    content: "● ● ●"; display: block; padding: 12px 18px; font-size: 11px; letter-spacing: 6px;
    color: #FF5F57; background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.01));
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .prose :global(pre code) {
    display: block; background: none; padding: 20px 22px; overflow-x: auto;
    font-family: 'JetBrains Mono', monospace; font-size: 13.5px; line-height: 1.8; color: var(--text);
  }
  .prose :global(blockquote) { border-left: 3px solid var(--orange); padding-left: 18px; margin: 24px 0; color: var(--muted); font-style: italic; }
  .prose :global(img) { max-width: 100%; border-radius: 12px; margin: 24px 0; }
  .prose :global(hr) { border: none; border-top: 1px dashed var(--border); margin: 40px 0; }

  @media (max-width: 760px) {
    .post-hero h1 { font-size: 28px; }
  }
</style>
