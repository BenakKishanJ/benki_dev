---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RevealScript from '../components/RevealScript.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  active?: 'posts' | 'about' | 'projects';
}

const { title, description = "Build logs, bugs, and the reasoning behind them.", active } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} — BenKi.dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Fraunces:ital,wght@1,500&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="cursor-glow" id="cursorGlow"></div>
  <Nav active={active} />
  <slot />
  <Footer />
  <RevealScript />
  <style is:global>
    .cursor-glow {
      position: fixed; top: 0; left: 0; width: 420px; height: 420px; border-radius: 50%;
      background: radial-gradient(circle, rgba(155,92,246,0.18), rgba(255,106,26,0.10) 40%, transparent 70%);
      pointer-events: none; z-index: 1; transform: translate(-50%, -50%);
      transition: opacity .3s ease; opacity: 0; will-change: transform;
    }
    @media (max-width: 900px) { .cursor-glow { display: none; } }
  </style>
  <script>
    const glow = document.getElementById('cursorGlow');
    window.addEventListener('mousemove', (e) => {
      if (!glow) return;
      glow.style.opacity = '1';
      glow.style.transform = `translate(${e.clientX}px, ${e.clientY}px) translate(-50%, -50%)`;
    });
  </script>
</body>
</html>
