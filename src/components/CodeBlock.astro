---
interface Props {
  code: string;
  lang?: string;
  filename?: string;
  class?: string;
}
const { code, lang = 'bash', filename, class: className = '' } = Astro.props;

// Simple token colouring — no external dep.
// For real syntax highlighting add shiki: `npm install shiki`
// and swap highlightCode() below with shiki's codeToHtml().
function highlightCode(src: string, language: string): string {
  const esc = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  const rules: Array<[RegExp, string]> = (() => {
    switch (language) {
      case 'typescript':
      case 'ts':
      case 'javascript':
      case 'js':
        return [
          [/(\/\/.*)/g,                              'clr-comment'],
          [/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'|`(?:[^`\\]|\\.)*`)/g, 'clr-str'],
          [/\b(const|let|var|function|return|if|else|for|while|class|interface|type|export|import|from|extends|new|async|await|void|string|number|boolean)\b/g, 'clr-kw'],
          [/\b(\d+\.?\d*)\b/g, 'clr-num'],
        ] as Array<[RegExp, string]>;
      case 'python':
      case 'py':
        return [
          [/(#.*)/g,              'clr-comment'],
          [/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/g, 'clr-str'],
          [/\b(def|class|return|if|elif|else|for|while|import|from|as|with|pass|None|True|False|and|or|not|in|is|lambda|self)\b/g, 'clr-kw'],
          [/\b(\d+\.?\d*)\b/g, 'clr-num'],
        ] as Array<[RegExp, string]>;
      case 'kotlin':
      case 'kt':
        return [
          [/(\/\/.*)/g,             'clr-comment'],
          [/("(?:[^"\\]|\\.)*")/g,  'clr-str'],
          [/\b(fun|val|var|class|data|sealed|object|return|if|else|when|for|while|suspend|override|private|public|internal|import|package|null|true|false|in|is)\b/g, 'clr-kw'],
          [/\b(\d+\.?\d*[Lf]?)\b/g, 'clr-num'],
        ] as Array<[RegExp, string]>;
      case 'sql':
        return [
          [/(--.*)/g, 'clr-comment'],
          [/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/g, 'clr-str'],
          [/\b(SELECT|FROM|WHERE|INSERT|UPDATE|DELETE|CREATE|TABLE|PRIMARY|KEY|REFERENCES|NOT|NULL|INTEGER|TEXT|INDEX|ON|AND|OR|IN|AS|AUTOINCREMENT|UNIQUE|DEFAULT|CHECK)\b/gi, 'clr-kw'],
          [/\b(\d+)\b/g, 'clr-num'],
        ] as Array<[RegExp, string]>;
      case 'css':
        return [
          [/(\/\*[\s\S]*?\*\/)/g,         'clr-comment'],
          [/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/g, 'clr-str'],
          [/(--[a-zA-Z-]+)/g,             'clr-kw'],
          [/(\d+\.?\d*(?:px|rem|em|%|vh|vw|deg|s|ms)?)/g, 'clr-num'],
        ] as Array<[RegExp, string]>;
      case 'astro':
        return [
          [/(\/\/.*|<!--[\s\S]*?-->)/g,   'clr-comment'],
          [/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'|`(?:[^`\\]|\\.)*`)/g, 'clr-str'],
          [/\b(const|let|import|from|export|interface|return|class)\b/g, 'clr-kw'],
        ] as Array<[RegExp, string]>;
      default: // bash / shell
        return [
          [/(#.*)/g,              'clr-comment'],
          [/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/g, 'clr-str'],
          [/\b(if|fi|then|else|elif|for|while|do|done|export|echo|exit|source)\b/g, 'clr-kw'],
          [/\$([A-Z_][A-Z0-9_]*)/g, 'clr-var'],
        ] as Array<[RegExp, string]>;
    }
  })();

  // Tokenise via placeholder substitution to avoid regex overlap
  const tokens: string[] = [];
  let processed = esc(src);

  rules.forEach(([rx, cls]) => {
    processed = processed.replace(rx, (m) => {
      const idx = tokens.length;
      tokens.push(`<span class="${cls}">${m}</span>`);
      return `\x00${idx}\x00`;
    });
  });

  // Restore tokens
  processed = processed.replace(/\x00(\d+)\x00/g, (_, i) => tokens[Number(i)]);
  return processed;
}

const highlighted = highlightCode(code.trim(), lang);
---

<div class={`codeblock reveal scale ${className}`}>
  <div class="cb-bar">
    <div class="cb-dots">
      <span class="terminal-dot red"></span>
      <span class="terminal-dot yellow"></span>
      <span class="terminal-dot green"></span>
    </div>
    {filename && <span class="cb-filename">{filename}</span>}
    <span class="cb-lang">{lang}</span>
    <button class="cb-copy" data-code={code.trim()} aria-label="Copy code">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <span class="cb-copy-label">Copy</span>
    </button>
  </div>
  <pre class="cb-pre"><code set:html={highlighted} /></pre>
</div>

<style>
  .codeblock { background: #0D0D14; border-radius: 14px; border: 1px solid rgba(255,255,255,0.10); box-shadow: 0 28px 64px rgba(0,0,0,0.50); overflow: hidden; }
  .cb-bar { display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.01)); border-bottom: 1px solid rgba(255,255,255,0.08); }
  .cb-dots { display: flex; gap: 7px; }
  .cb-filename { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--muted); margin-left: 6px; }
  .cb-lang { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; color: var(--muted); margin-left: auto; opacity: 0.6; letter-spacing: 0.06em; text-transform: uppercase; }
  .cb-copy { display: flex; align-items: center; gap: 5px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); color: var(--muted); border-radius: 6px; padding: 5px 10px; font-size: 11.5px; cursor: pointer; transition: background .2s, color .2s; }
  .cb-copy:hover { background: rgba(255,255,255,0.12); color: var(--text); }
  .cb-copy.copied { color: var(--lime); border-color: var(--lime); }
  .cb-pre { margin: 0; padding: 20px 22px; overflow-x: auto; }
  .cb-pre code { font-family: 'JetBrains Mono', monospace; font-size: 13.5px; line-height: 1.85; white-space: pre; display: block; color: #C9C0E0; }

  /* token colours */
  :global(.clr-comment) { color: #625C7B; font-style: italic; }
  :global(.clr-str)     { color: var(--yellow); }
  :global(.clr-kw)      { color: var(--purple-2); }
  :global(.clr-num)     { color: var(--blue); }
  :global(.clr-var)     { color: var(--orange-2); }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.cb-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.dataset.code ?? '';
      await navigator.clipboard.writeText(code).catch(() => {});
      const label = btn.querySelector('.cb-copy-label');
      if (label) { label.textContent = 'Copied!'; btn.classList.add('copied'); }
      setTimeout(() => {
        if (label) { label.textContent = 'Copy'; btn.classList.remove('copied'); }
      }, 2000);
    });
  });
</script>
