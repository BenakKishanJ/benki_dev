---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabel: Record<string, string> = {
  'system-design': 'System design',
  'dsa': 'DSA',
  'error-fix': 'Error fix',
  'frameworks': 'Frameworks',
};
---
<Layout title="Posts" active="posts">
  <section class="dark page-hero">
    <div class="blob" style="width:340px;height:340px;top:-90px;left:10%;background:var(--purple);"></div>
    <div class="eyebrow">All posts</div>
    <h1 class="reveal in">Everything I've shipped, <span class="gradient-text">broken</span>, and written down.</h1>
    <p class="reveal in muted">Filter by category, or just scroll — every post is a real bug, a real formula, or a real architecture decision.</p>
  </section>

  <div class="dark filter-bar reveal in">
    <button class="filter-pill active" data-filter="all" style="--c:var(--text)"><span class="dot" style="background:#F5F3FA"></span> All</button>
    <button class="filter-pill" data-filter="system-design" style="--c:var(--purple)"><span class="dot" style="background:var(--purple)"></span> System design</button>
    <button class="filter-pill" data-filter="dsa" style="--c:var(--blue)"><span class="dot" style="background:var(--blue)"></span> DSA</button>
    <button class="filter-pill" data-filter="error-fix" style="--c:var(--orange)"><span class="dot" style="background:var(--orange)"></span> Error fixes</button>
    <button class="filter-pill" data-filter="frameworks" style="--c:var(--lime)"><span class="dot" style="background:var(--lime)"></span> Frameworks</button>
  </div>

  <section class="dark posts-wrap">
    <div class="post-grid" id="postGrid">
      {allPosts.map((post, i) => (
        <a href={`/blog/${post.id}`} class="post-card tilt reveal scale" data-cat={post.data.category} style={`transition-delay:${i * 50}ms`}>
          <span class={`badge ${post.data.category}`}>{categoryLabel[post.data.category]}</span>
          <h3>{post.data.title}</h3>
          <p class="muted">{post.data.description}</p>
          <div class="post-meta muted">
            <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
            {post.data.readingTime && <><span>·</span><span>{post.data.readingTime}</span></>}
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-hero { position: relative; max-width: 1140px; margin: 0 auto; padding: 84px 32px 50px; }
  .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--orange-2); margin-bottom: 16px; }
  .page-hero h1 { font-size: 44px; font-weight: 800; line-height: 1.1; max-width: 680px; }
  .page-hero p { margin-top: 18px; font-size: 16.5px; max-width: 540px; line-height: 1.6; }

  .filter-bar { max-width: 1140px; margin: 0 auto; padding: 0 32px 50px; display: flex; gap: 12px; flex-wrap: wrap; }
  .filter-pill { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; padding: 9px 18px; border-radius: 999px; border: 1px solid var(--border); color: var(--muted); display: flex; align-items: center; gap: 8px; cursor: pointer; transition: border-color .2s, color .2s, transform .2s, box-shadow .2s; background: transparent; }
  .filter-pill:hover { transform: translateY(-2px); }
  .filter-pill.active { border-color: var(--c); color: var(--text); box-shadow: 0 0 0 1px var(--c) inset, 0 8px 20px color-mix(in srgb, var(--c) 30%, transparent); }
  .filter-pill .dot { width: 7px; height: 7px; border-radius: 50%; }

  .posts-wrap { max-width: 1140px; margin: 0 auto; padding: 0 32px 100px; }
  .post-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .post-card { background: rgba(255,255,255,0.035); border: 1px solid var(--border); border-radius: 16px; padding: 26px; display: flex; flex-direction: column; gap: 14px; transition: border-color .25s ease, box-shadow .25s ease; }
  .post-card:hover { border-color: rgba(255,255,255,0.22); box-shadow: 0 22px 50px rgba(0,0,0,0.45); }
  .post-card h3 { font-size: 19px; font-weight: 700; line-height: 1.3; }
  .post-card p { font-size: 14.5px; line-height: 1.6; }
  .post-meta { font-size: 12px; font-family: 'JetBrains Mono', monospace; display: flex; gap: 8px; }

  @media (max-width: 760px) {
    .post-grid { grid-template-columns: 1fr; }
    .page-hero h1 { font-size: 32px; }
  }
</style>

<script>
  const pills = document.querySelectorAll('.filter-pill');
  const cards = document.querySelectorAll('#postGrid .post-card');
  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = (pill as HTMLElement).dataset.filter;
      cards.forEach((card) => {
        const cat = (card as HTMLElement).dataset.cat;
        const show = filter === 'all' || cat === filter;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>
