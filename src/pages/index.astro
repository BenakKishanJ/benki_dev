---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = allPosts.slice(0, 4);

const categoryLabel: Record<string, string> = {
  'system-design': 'System design',
  'dsa': 'DSA',
  'error-fix': 'Error fix',
  'frameworks': 'Frameworks',
};

const categories = [
  { key: 'system-design', label: 'System design', color: 'var(--purple)', desc: 'Architecture calls, trade-offs, and the diagrams behind them.' },
  { key: 'dsa', label: 'DSA', color: 'var(--blue)', desc: 'LeetCode traces, patterns, and the bug in my mental model.' },
  { key: 'error-fix', label: 'Error fixes', color: 'var(--orange)', desc: 'The exact stack trace, the exact fix, no fluff.' },
  { key: 'frameworks', label: 'Frameworks', color: 'var(--lime)', desc: 'React, Astro, Kotlin — deep dives as I actually learn them.' },
];
---
<Layout title="Build logs, bugs, and the reasoning behind them">
  <section class="dark hero">
    <div class="blob" style="width:420px;height:420px;top:-120px;left:-160px;background:var(--orange);"></div>
    <div class="blob" style="width:380px;height:380px;top:-60px;right:-140px;background:var(--purple);animation-delay:-4s;"></div>
    <div class="hero-grid">
      <div>
        <div class="eyebrow">Currently debugging life</div>
        <h1 class="reveal in">Build logs, <span class="gradient-text">debugged bugs</span>,<br />and interview prep that doesn't lie to you.</h1>
        <p class="lede reveal in">Android, GenAI, DSA, and system design — written the way I actually learn it: messy first, then formalized. Recent grad, shipping solo, logging the leetcode grind along the way.</p>
        <div class="hero-cta reveal in">
          <a class="btn btn-primary magnetic" href="/blog">Read the logs →</a>
          <a class="btn btn-ghost magnetic" href="/about">About me</a>
        </div>
        <div class="stat-row reveal in">
          <div class="stat"><span class="num" data-count="3">0</span><span class="label">posts shipped</span></div>
          <div class="stat"><span class="num" data-count="120">0</span><span class="label">leetcode solved</span></div>
          <div class="stat"><span class="num" data-count="2">0</span><span class="label">am debugging sessions</span></div>
        </div>
      </div>
      <Terminal title="bug-hunt.sh" class="hero-terminal">
        <div class="line"><span class="terminal-prompt">benki@dev</span> <span class="terminal-path">~/kirana-sync</span> $ <span id="typeLine"></span><span class="terminal-cursor"></span></div>
        <div class="line">&nbsp;</div>
        <div class="line terminal-comment"># 3 hours later...</div>
        <div class="line"><span class="terminal-kw">if</span> lo &lt;= hi: <span class="terminal-comment">// the missing "="</span></div>
        <div class="line">&nbsp;&nbsp;mid = (lo + hi) // 2</div>
        <div class="line terminal-out">✓ off-by-one fixed</div>
        <div class="line terminal-out">✓ tests passing <span class="terminal-str">(14/14)</span></div>
      </Terminal>
    </div>
  </section>

  <section class="marquee-wrap">
    <div class="marquee">
      <div class="marquee-track">
        <span>SYSTEM DESIGN</span><span>·</span><span>DSA</span><span>·</span><span>ERROR FIXES</span><span>·</span><span>FRAMEWORKS</span><span>·</span><span>ANDROID</span><span>·</span><span>GENAI</span><span>·</span>
        <span>SYSTEM DESIGN</span><span>·</span><span>DSA</span><span>·</span><span>ERROR FIXES</span><span>·</span><span>FRAMEWORKS</span><span>·</span><span>ANDROID</span><span>·</span><span>GENAI</span><span>·</span>
      </div>
    </div>
  </section>

  <section class="dark cat-section">
    <div class="section-head reveal">
      <h2>Notes from the <span class="serif-accent">fire</span>, written while it's still warm.</h2>
      <p class="sub muted">Every post is tagged by what it actually is — not by what category sounds impressive.</p>
    </div>
    <div class="cat-grid">
      {categories.map((c, i) => (
        <div class="cat-card tilt reveal scale" style={`--c:${c.color}; transition-delay:${i * 70}ms`}>
          <span class="cat-dot" style={`background:${c.color}`}></span>
          <h3>{c.label}</h3>
          <p class="muted">{c.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="dark posts">
    <div class="section-head reveal">
      <h2>Recent posts</h2>
      <a class="see-all" href="/blog">View all →</a>
    </div>
    <div class="post-grid">
      {recentPosts.map((post, i) => (
        <a href={`/blog/${post.id}`} class="post-card tilt reveal scale" style={`transition-delay:${i * 60}ms`}>
          <span class={`badge ${post.data.category}`}>{categoryLabel[post.data.category]}</span>
          <h3>{post.data.title}</h3>
          <p class="muted">{post.data.description}</p>
          <div class="post-meta muted">
            <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
            {post.data.readingTime && <><span>·</span><span>{post.data.readingTime}</span></>}
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero { position: relative; max-width: 1140px; margin: 0 auto; padding: 90px 32px 60px; }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 56px; align-items: center; }
  .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--orange-2); margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
  .eyebrow::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--orange); box-shadow: 0 0 12px rgba(255,106,26,0.8); animation: blink 1.6s ease-in-out infinite; }
  .hero h1 { font-size: 52px; font-weight: 800; line-height: 1.08; }
  .hero p.lede { margin-top: 22px; font-size: 17.5px; color: var(--muted); max-width: 520px; line-height: 1.6; }
  .hero-cta { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
  .hero-terminal :global(.terminal-body) { min-height: 220px; }

  .stat-row { display: flex; gap: 36px; margin-top: 44px; }
  .stat { display: flex; flex-direction: column; }
  .stat .num { font-family: 'Bricolage Grotesque', sans-serif; font-size: 30px; font-weight: 800; background: var(--grad-main); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .stat .label { font-size: 12px; color: var(--muted); margin-top: 2px; }

  .marquee-wrap { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: rgba(255,255,255,0.02); margin: 20px 0; }
  .marquee { overflow: hidden; padding: 16px 0; }
  .marquee-track { display: flex; gap: 18px; width: max-content; animation: marquee 22s linear infinite; font-family: 'JetBrains Mono', monospace; font-size: 13px; letter-spacing: 0.06em; color: var(--muted); }
  .marquee-track span:nth-child(4n+1) { color: var(--orange-2); }
  .marquee-track span:nth-child(4n+2) { color: var(--purple-2); }
  .marquee-track span:nth-child(4n+3) { color: var(--blue); }

  .cat-section { max-width: 1140px; margin: 0 auto; padding: 90px 32px 30px; }
  .section-head h2 { font-size: 34px; font-weight: 800; line-height: 1.18; max-width: 620px; }
  .section-head .sub { margin-top: 14px; font-size: 15.5px; max-width: 480px; line-height: 1.6; }

  .cat-grid { margin-top: 40px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .cat-card { background: rgba(255,255,255,0.035); border: 1px solid var(--border); border-radius: 18px; padding: 26px; transition: border-color .3s ease, box-shadow .3s ease; }
  .cat-card:hover { border-color: var(--c); box-shadow: 0 20px 50px -10px color-mix(in srgb, var(--c) 40%, transparent); }
  .cat-dot { display: block; width: 14px; height: 14px; border-radius: 5px; margin-bottom: 16px; box-shadow: 0 0 16px color-mix(in srgb, var(--c) 70%, transparent); }
  .cat-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .cat-card p { font-size: 13.5px; line-height: 1.55; }

  .posts { max-width: 1140px; margin: 0 auto; padding: 70px 32px 100px; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 30px; }
  .posts .section-head h2 { font-size: 26px; }
  .see-all { font-size: 14px; color: var(--muted); transition: color .2s ease; }
  .see-all:hover { color: var(--orange-2); }

  .post-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .post-card { background: rgba(255,255,255,0.035); border: 1px solid var(--border); border-radius: 16px; padding: 26px; display: flex; flex-direction: column; gap: 14px; transition: border-color 0.25s ease, box-shadow 0.25s ease; transform-style: preserve-3d; }
  .post-card:hover { border-color: rgba(255,255,255,0.22); box-shadow: 0 22px 50px rgba(0,0,0,0.45); }
  .post-card h3 { font-size: 19px; font-weight: 700; line-height: 1.3; }
  .post-card p { font-size: 14.5px; line-height: 1.6; }
  .post-meta { font-size: 12px; font-family: 'JetBrains Mono', monospace; display: flex; gap: 8px; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .post-grid { grid-template-columns: 1fr; }
    .cat-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: 32px; }
    .stat-row { gap: 24px; flex-wrap: wrap; }
  }
</style>

<script>
  // typewriter line in hero terminal
  const el = document.getElementById('typeLine');
  const text = 'git blame search.py';
  if (el) {
    let i = 0;
    const type = () => {
      if (i <= text.length) { el.textContent = text.slice(0, i); i++; setTimeout(type, 70); }
    };
    type();
  }

  // count-up stats
  const nums = document.querySelectorAll<HTMLElement>('.stat .num');
  const animateNum = (n: HTMLElement) => {
    const target = parseInt(n.dataset.count || '0', 10);
    let cur = 0;
    const step = Math.max(1, Math.ceil(target / 40));
    const tick = () => {
      cur = Math.min(target, cur + step);
      n.textContent = String(cur);
      if (cur < target) requestAnimationFrame(tick);
    };
    tick();
  };
  const statObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        animateNum(entry.target as HTMLElement);
        statObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });
  nums.forEach((n) => statObserver.observe(n));
</script>
